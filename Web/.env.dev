#Cyber Clinic environment variable configuration
#CS 425 Team 13 - Development environment variables

#frontend
HOST=localhost # This thould be the IP or domain name of the machine running the docker containers
FRONTEND_SERVER=frontend
FRONTEND_PORT=3000

#Ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

#backend
SCAN_DIR=/src/scans
REPORT_DIR=/src/reports
#web variables
BACKEND_SERVER=cyberclinic-backend
#-- windows/linux start
BACKEND_PORT=5000
#-- windows/linux end
#-- macOS start (port 5000 is reserved by AirPlay Receiver)
# BACKEND_PORT=5001
#-- macOS end

FLASK_SECRET_KEY=dev-secret-key-change-in-production

#   Standalone-related Variables
SERVER_CNF=/src/certs/server.cnf

AUTH_PORT=6666
AUTH_CRT=/src/certs/auth.crt
AUTH_KEY=/src/certs/auth.key
AUTH_PASS=cyberclinicdev

AUTHED_PORT=9999
AUTHED_CRT=/src/certs/authed.crt
AUTHED_KEY=/src/certs/authed.key
AUTHED_PASS=cyberclinicdev

#Database
#database connection settings for our postgresql database
#docker-compose uses these to set up the database container
DB_NAME=cyberclinic
DB_USER=cyberclinic_user  
DB_PASS=dev_password_change_in_production
DB_PORT=5432

#Email - uncomment ONE provider block, leave others commented
#View local test emails at http://localhost:8025 (Mailhog must be running)

#-- Mailhog (local dev, no credentials needed) --
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cyberclinic.unr.edu

#-- Gmail --
#Requires App Password: Google Account > Security > 2-Step Verification > App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# EMAIL_FROM=your@gmail.com

#-- Outlook / Hotmail --
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your@outlook.com
# SMTP_PASS=your-password
# EMAIL_FROM=your@outlook.com

#-- UNR.edu (Microsoft 365, same server as Outlook) --
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your@unr.edu
# SMTP_PASS=your-unr-password
# EMAIL_FROM=your@unr.edu

APP_BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

