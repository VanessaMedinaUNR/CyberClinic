#Cyber Clinic environment variable configuration
#CS 425 Team 13 - Development environment variables

#frontend
HOST=localhost
FRONTEND_SERVER=frontend
FRONTEND_PORT=3000

#backend
SCAN_DIR=/src/scans
REPORT_DIR=/src/reports
#web variables
BACKEND_SERVER=cyberclinic-backend
#-- windows/linux start
BACKEND_PORT=5000
#-- windows/linux end
#-- macOS start (port 5000 is reserved by AirPlay Receiver)
# BACKEND_PORT=5001
#-- macOS end

FLASK_SECRET_KEY=dev-secret-key-change-in-production

#   Standalone-related Variables
SERVER_CNF=/src/certs/server.cnf

AUTH_PORT=6666
AUTH_CRT=/src/certs/auth.crt
AUTH_KEY=/src/certs/auth.key
AUTH_PASS=cyberclinicdev

AUTHED_PORT=9999
AUTHED_CRT=/src/certs/authed.crt
AUTHED_KEY=/src/certs/authed.key
AUTHED_PASS=cyberclinicdev

#Database
#database connection settings for our postgresql database
#docker-compose uses these to set up the database container
DB_NAME=cyberclinic
DB_USER=cyberclinic_user  
DB_PASS=dev_password_change_in_production

#network settings so our backend can talk to the database
#hostname is 'database' because that's what docker-compose calls it
DB_HOST=database
DB_PORT=5432

#Done by Austin Finch