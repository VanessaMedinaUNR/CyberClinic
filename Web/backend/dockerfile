FROM python:3.11-slim AS builder

ARG AUTHED_CRT
ENV AUTHED_CRT=$AUTHED_CRT

WORKDIR /src

#install system dependencies and scanning tools
RUN apt-get update && apt-get install -y \
    gcc \
    nmap \
    curl \
    wget \
    git \
    perl \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

#install Nikto from GitHub since it's not in main repos
RUN git clone https://github.com/sullo/nikto.git /opt/nikto \
    && ln -s /opt/nikto/program/nikto.pl /usr/local/bin/nikto \
    && chmod +x /opt/nikto/program/nikto.pl

#copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

#copy application code
COPY . .

RUN openssl x509 -in ${AUTHED_CRT} -outform PEM -out /usr/local/share/ca-certificates/CyberClinicCA.crt
RUN update-ca-certificates

#create non-root user for security
RUN useradd --create-home --shell /bin/bash app \
    && chown -R app:app /src
USER app

ENTRYPOINT ["python", "main.py"]


